{
  "version": 8,
  "name": "Natural Earth",
  "sources": {
    "natural_earth": {
      "type": "vector",
      "tiles": ["https://appassets.androidplatform.net/mbtiles/{z}/{x}/{y}.pbf"],
      "minzoom": 0,
      "maxzoom": 10
    }
  },
  "layers": [

    {
      "id": "background",
      "type": "background",
      "paint": {
        "background-color": "#a8d4f5"
      }
    },

    {
      "id": "countries-fill",
      "type": "fill",
      "source": "natural_earth",
      "source-layer": "countries",
      "paint": {
        "fill-color": "#e8e0d0",
        "fill-outline-color": "#b0a090"
      }
    },

    {
      "id": "countries-border",
      "type": "line",
      "source": "natural_earth",
      "source-layer": "countries",
      "paint": {
        "line-color": "#998877",
        "line-width": ["interpolate", ["linear"], ["zoom"], 0, 0.4, 6, 1.2]
      }
    },

    {
      "id": "minor-islands-fill",
      "type": "fill",
      "source": "natural_earth",
      "source-layer": "minor_islands",
      "minzoom": 4,
      "paint": {
        "fill-color": "#e8e0d0",
        "fill-outline-color": "#b0a090"
      }
    },

    {
      "id": "lakes-fill",
      "type": "fill",
      "source": "natural_earth",
      "source-layer": "lakes",
      "paint": {
        "fill-color": "#a8d4f5",
        "fill-outline-color": "#7ab8e8"
      }
    },

    {
      "id": "rivers-line",
      "type": "line",
      "source": "natural_earth",
      "source-layer": "rivers",
      "paint": {
        "line-color": "#7ab8e8",
        "line-width": [
          "interpolate", ["linear"], ["zoom"],
          0, 0.5,
          6, 0.75
        ]
      }
    },

    {
      "id": "urban-areas-fill",
      "type": "fill",
      "source": "natural_earth",
      "source-layer": "urban_areas",
      "minzoom": 4,
      "paint": {
        "fill-color": "#d4c9b8",
        "fill-opacity": 0.7
      }
    },

    {
      "id": "populated-places-label",
      "type": "symbol",
      "source": "natural_earth",
      "source-layer": "populated_places",
      "minzoom": 2,
      "layout": {
        "text-field": ["get", "NAME"],
        "text-font": ["Open Sans Regular"],
        "text-size": ["interpolate", ["linear"], ["zoom"], 2, 8, 6, 11, 10, 13],
        "text-anchor": "bottom",
        "text-offset": [0, -0.3],
        "icon-allow-overlap": false,
        "text-allow-overlap": false
      },
      "paint": {
        "text-color": "#333333",
        "text-halo-color": "rgba(255,255,255,0.8)",
        "text-halo-width": 1.5
      }
    }
  ],
  "glyphs": "https://appassets.androidplatform.net/assets/web/fonts/{fontstack}/{range}.pbf"
}